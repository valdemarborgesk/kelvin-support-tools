{
  "id": "api/endpoints/control-change/getControlChange",
  "title": "Get Control Change",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Get Control Change\n\nRetrieves the properties, status and all associated logs of a Control Change.\n\n## Endpoint\n\n`GET /control-changes/{control_change_id}/get`",
  "summary": "Get Control Change",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/control-changes/{control_change_id}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.control_change.getControlChange()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/control-change"
  ],
  "tags": [
    "control-change",
    "api",
    "get"
  ],
