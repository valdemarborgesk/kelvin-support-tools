            },
            "trace_id": {
              "type": "string",
              "example": "app-trace-123",
              "maxLength": 256
            },
            "last_message": {
              "type": "string",
              "example": "The Control Change was sent to the Bridge. At this stage, the system is monitoring according to the Acceptance Criteria parameters and the retry logic.",
