                },
                "instantly_apply": {
                  "type": "boolean",
                  "example": true,
                  "description": "Whether the staged workload should be instantly applied or not."
                },
                "status": {
                  "type": "object",
                  "description": "Realtime information about the Staged Workload as seen from the Cloud.",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Descriptive, human-readable string for `state`."
                    },
                    "state": {
                      "type": "string",
                      "enum": [
                        "pending_deploy",
                        "pending_update",
                        "pending_start",
                        "pending_stop",
                        "pending_apply",
                        "deploying",
                        "running",
                        "stopping",
                        "stopped",
                        "failed",
                        "starting",
                        "applying",
                        "received",
                        "downloading",
                        "ready",
                        "unreachable",
                        "staged"
                      ]
                    },
                    "warnings": {
                      "type": "array",
                      "description": "All warnings received for any Staged Workload operations.",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "type": "object"
        }
      },
