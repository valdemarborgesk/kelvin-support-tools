      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/users/settings/{setting_name}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.user.getUserSettings()\nprint(response)"
