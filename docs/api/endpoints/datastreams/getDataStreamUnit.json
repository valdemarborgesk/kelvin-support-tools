{
  "id": "api/endpoints/datastreams/getDataStreamUnit",
  "title": "Get Unit",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Get Unit\n\nRetrieve the parameters of a Unit.\n\n## Endpoint\n\n`GET /datastreams/units/{unit_name}/get`",
  "summary": "Get Unit",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/datastreams/units/{unit_name}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.datastreams.getDataStreamUnit()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/datastreams"
  ],
  "tags": [
    "datastreams",
    "api",
    "get"
  ],
  "metadata": {
    "path": "/datastreams/units/{unit_name}/get",
    "method": "GET",
    "operation_id": "getDataStreamUnit",
    "tag": "Datastreams",
    "permission": "kelvin.permission.datastreams.read",
    "parameters": [
      {
        "name": "unit_name",
        "in": "path",
        "required": true,
        "description": "Unit parameter `name` to get. The string can only contain lowercase alphanumeric characters and `.`, `_` or `-` characters.",
        "type": "string"
      }
    ],
    "request_body": null,
    "responses": {
      "200": {
        "description": "OK",
        "schema": {
          "properties": {
            "created": {
              "type": "string",
              "format": "date-time",
              "example": "2023-06-26T18:22:18.582724Z",
              "description": "UTC time when the Unit was first created, formatted in RFC 3339."
            },
            "name": {
              "type": "string",
              "format": "^[a-z0-9]([-_.a-z0-9]*[a-z0-9])?$",
              "example": "degree_fahrenheit",
              "maxLength": 64,
              "description": "Unique identifier `name` of the Unit."
            },
            "symbol": {
              "type": "string",
              "example": "°F",
              "maxLength": 16,
              "description": "A brief and precise character or set of characters that symbolize a specific measurement of the Unit."
            },
            "title": {
              "type": "string",
              "example": "Degree Fahrenheit",
              "maxLength": 64,
              "description": "Display name (`title`) of the Unit."
            },
            "updated": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when any Unit keys were last updated, formatted in RFC 3339."
            }
          },
          "type": "object"
        }
      },
      "400": {
        "description": ""
      },
      "401": {
        "description": ""
      },
      "404": {
        "description": ""
      }
    },
