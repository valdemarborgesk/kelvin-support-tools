{
  "id": "api/endpoints/datastreams/updateDataStreamUnit",
  "title": "Update Unit",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Update Unit\n\nUpdates an existing Unit with any new values passed through the body parameters. All body parameters are optional and if not provided will remain unchanged.\n\n## Endpoint\n\n`POST /datastreams/units/{unit_name}/update`",
  "summary": "Update Unit",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/datastreams/units/{unit_name}/update' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.datastreams.updateDataStreamUnit()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/datastreams"
  ],
  "tags": [
    "datastreams",
    "api",
    "post"
  ],
  "metadata": {
    "path": "/datastreams/units/{unit_name}/update",
    "method": "POST",
    "operation_id": "updateDataStreamUnit",
    "tag": "Datastreams",
    "permission": "kelvin.permission.datastreams.update",
    "parameters": [
      {
        "name": "unit_name",
        "in": "path",
        "required": true,
        "description": "Unit parameter `name` to get. The string can only contain lowercase alphanumeric characters and `.`, `_` or `-` characters.",
        "type": "string"
      }
    ],
    "request_body": {
      "content_type": "application/json",
      "required": true,
      "schema": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "example": "°F",
            "minLength": 1,
            "maxLength": 16,
            "description": "A brief and precise character or set of characters that symbolize a specific measurement of the Unit."
          },
          "title": {
            "type": "string",
            "example": "Degree Fahrenheit",
            "minLength": 1,
            "maxLength": 64,
            "description": "Display name (`title`) of the Unit."
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK",
        "schema": {
          "properties": {
            "created": {
              "type": "string",
              "format": "date-time",
              "example": "2023-06-26T18:22:18.582724Z",
              "description": "UTC time when the Unit was first created, formatted in RFC 3339."
            },
            "name": {
              "type": "string",
              "format": "^[a-z0-9]([-_.a-z0-9]*[a-z0-9])?$",
              "example": "degree_fahrenheit",
              "maxLength": 64,
              "description": "Unique identifier `name` of the Unit."
            },
            "symbol": {
              "type": "string",
              "example": "°F",
              "maxLength": 16,
              "description": "A brief and precise character or set of characters that symbolize a specific measurement of the Unit."
            },
            "title": {
              "type": "string",
              "example": "Degree Fahrenheit",
              "maxLength": 64,
              "description": "Display name (`title`) of the Unit."
            },
            "updated": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when any Unit keys were last updated, formatted in RFC 3339."
            }
          },
          "type": "object"
        }
      },
      "400": {
        "description": ""
      },
      "401": {
        "description": ""
      },
      "404": {
        "description": ""
      }
    },
