  "id": "api/endpoints/data-quality/DataQualitySimulate",
  "title": "Data Quality Simulate",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Data Quality Simulate\n\nSimulate the effect of data quality updates without making permanent changes.\n\n## Endpoint\n\n`POST /data-quality/simulate`",
  "summary": "Data Quality Simulate",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/data-quality/simulate' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.data_quality.DataQualitySimulate()\nprint(response)"
    }
