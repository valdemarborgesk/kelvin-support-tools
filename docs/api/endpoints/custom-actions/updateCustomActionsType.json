{
  "id": "api/endpoints/custom-actions/updateCustomActionsType",
  "title": "Update Custom Action Type",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Update Custom Action Type\n\nUpdates an existing Custom Action Type with any new values passed through the body parameters. All body parameters are optional and if not provided will remain unchanged. Only the unique identifier `name` can not be changed.\n\n## Endpoint\n\n`POST /custom-actions/types/{name}/update`",
  "summary": "Update Custom Action Type",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/custom-actions/types/{name}/update' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.custom_actions.updateCustomActionsType()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/custom-actions"
  ],
  "tags": [
    "custom-actions",
    "api",
    "post"
  ],
  "metadata": {
    "path": "/custom-actions/types/{name}/update",
    "method": "POST",
    "operation_id": "updateCustomActionsType",
    "tag": "Custom Actions",
    "permission": "kelvin.permission.custom-actions.update",
    "parameters": [
      {
        "name": "name",
        "in": "path",
        "required": true,
        "description": "Custom Action Type key `name` to update. Case sensitive name.",
        "type": "string"
      }
    ],
    "request_body": {
      "content_type": "application/json",
      "required": true,
      "schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Email",
            "minLength": 1,
            "maxLength": 64
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK",
        "schema": {
          "properties": {
            "created": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when the Custom Action Type was created, formatted in RFC 3339."
            },
            "created_by": {
              "type": "string",
              "format": "krn",
              "example": "krn:user:email@kelvininc.com",
              "description": "The user or process that initiated the creation of this custom action type."
            },
            "name": {
              "type": "string",
              "format": "^[a-zA-Z0-9]([-_ .a-zA-Z0-9]*[a-zA-Z0-9])?$",
              "example": "Email",
              "maxLength": 64,
              "description": "Unique identifier `name` for the Custom Action Type."
            },
            "title": {
              "type": "string",
              "example": "Email",
              "maxLength": 64
            },
            "updated": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when any Custom Action Type keys were last updated, formatted in RFC 3339."
            },
            "updated_by": {
              "type": "string",
              "format": "krn",
              "example": "krn:user:email@kelvininc.com",
              "description": "The user or process that updated this custom action type."
            }
          },
          "type": "object"
        }
      },
