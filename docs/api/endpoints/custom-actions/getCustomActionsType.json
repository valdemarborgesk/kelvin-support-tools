  "type": "api_endpoint",
  "category": "api",
  "content": "# Get Custom Action Type\n\nRetrieves the parameters of a Custom Action Type.\n\n## Endpoint\n\n`GET /custom-actions/types/{name}/get`",
  "summary": "Get Custom Action Type",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/custom-actions/types/{name}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.custom_actions.getCustomActionsType()\nprint(response)"
    }
