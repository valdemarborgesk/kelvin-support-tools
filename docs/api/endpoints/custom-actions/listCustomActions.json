    "request_body": {
      "content_type": "application/json",
      "required": true,
      "schema": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "example": [
              "0002bc79-b42f-461b-95d6-cf0a28ba87aa",
              "00080f9e-d086-452d-b41d-c8aa8fb27c92"
            ],
            "description": "Search and filter on the list based on the key `id`. The filter is on the full UUID `id` only. All strings in the array are treated as `OR`.",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "resources": {
            "type": "array",
            "example": [
              "krn:asset:bp_16",
              "krn:asset:bp_21"
            ],
            "description": "A filter on the list showing only Recommendations associated with any Assets in the array. The filter is on the full KRN Asset name only. All strings in the array are treated as `OR`. Each Asset name must be in the KRN format.",
            "items": {
              "type": "string",
              "format": "krn",
              "minLength": 1,
              "maxLength": 256
            }
          },
          "created_by": {
            "type": "array",
            "example": [
              "krn:wlappv:cluster1/app1/1.2.0",
              "krn:user:richard.teo@kelvininc.com"
            ],
            "description": "A filter on the list showing only Custom Action created by a certain source. The filter is on the full `source` KRN name only. All strings in the array are treated as `OR`.",
            "items": {
              "type": "string",
              "format": "krn",
              "minLength": 1,
              "maxLength": 256
            }
          },
          "states": {
            "type": "array",
            "example": [
              "ready",
              "pending"
            ],
            "description": "A filter on the list showing only Custom Action associated with one or more `states`. The filter is on the full `state` name only. All strings in the array are treated as `OR`.",
            "items": {
              "type": "string",
              "description": "The state of an action.",
              "enum": [
                "pending",
                "ready",
                "in_progress",
                "completed",
                "cancelled",
                "failed"
              ]
            }
          },
          "types": {
            "type": "array",
            "example": [
              "Email"
            ],
            "description": "A filter on the list showing only Custom Actions associated with one or more Custom Action Types. The filter is on the full Custom Action Type `name` only. All strings in the array are treated as `OR`.",
            "items": {
              "type": "string",
              "format": "^[a-zA-Z0-9]([-_ .a-zA-Z0-9]*[a-zA-Z0-9])?$",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "trace_ids": {
            "type": "array",
            "example": [
              "trace id change 123"
            ],
            "description": "A filter on the list showing only Custom Actions associated with one or more Trace IDs.",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            }
          }
        }
      }
    },
