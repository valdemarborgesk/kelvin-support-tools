      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/assets/types/delete' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.asset.deleteAssetTypeBulk()\nprint(response)"
    }
