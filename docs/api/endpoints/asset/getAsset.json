{
  "id": "api/endpoints/asset/getAsset",
  "title": "Get Asset",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Get Asset\n\nRetrieve the parameters of an Asset.\n\n## Endpoint\n\n`GET /assets/{asset_name}/get`",
  "summary": "Get Asset",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/assets/{asset_name}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.asset.getAsset()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/asset"
  ],
  "tags": [
    "asset",
    "api",
    "get"
  ],
  "metadata": {
    "path": "/assets/{asset_name}/get",
    "method": "GET",
    "operation_id": "getAsset",
    "tag": "Asset",
    "permission": "kelvin.permission.asset.read",
    "parameters": [
      {
        "name": "asset_name",
        "in": "path",
        "required": true,
        "description": "Asset key `name` to get. The string can only contain lowercase alphanumeric characters and `.`, `_` or `-` characters.",
        "type": "string"
      }
    ],
    "request_body": null,
    "responses": {
      "200": {
        "description": "OK",
        "schema": {
          "properties": {
            "asset_type_name": {
              "type": "string",
              "example": "beam_pump",
              "format": "^[a-z0-9]([-_.a-z0-9]*[a-z0-9])?$",
              "maxLength": 64,
              "description": "Unique identifier `name` of the Asset Type linked to this Asset."
            },
            "asset_type_title": {
              "type": "string",
              "example": "Beam Pump",
              "maxLength": 64,
              "description": "Display name (`title`) of the Asset Type linked to this Asset."
            },
            "created": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when the Asset was created, formatted in RFC 3339."
            },
            "name": {
              "type": "string",
              "format": "^[a-z0-9]([-_.a-z0-9]*[a-z0-9])?$",
              "example": "well_01",
              "maxLength": 64,
              "description": "Unique identifier `name` of the Asset."
            },
            "properties": {
              "type": "array",
              "description": "Array of custom properties. These properties are not used by the Kelvin Platform and are for end-user use only.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "format": "^[a-z0-9]([-_.a-z0-9]*[a-z0-9])?$",
                    "example": "water-line-pressure",
                    "maxLength": 64,
                    "description": "Unique identifier `name` for the Asset Property. The string can only contain lowercase alphanumeric characters and `.`, `_` or `-` characters."
                  },
                  "title": {
                    "type": "string",
                    "example": "Water Line Pressure",
                    "maxLength": 64,
                    "description": "Display name (title) for the Asset Property. You can use any character, numeric, space and special character in this key."
                  },
                  "value": {
                    "oneOf": [
                      {
                        "type": "number"
                      },
                      {
                        "type": "string"
                      },
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "boolean"
                        }
                      }
                    ]
                  }
                }
              }
            },
            "in_use_by": {
              "type": "array",
              "description": "List of workload sources that are using this Asset.",
              "items": {
                "type": "string",
                "format": "krn",
                "example": "krn:wlappv:cluster1/workload1/app1/1.2.0"
              }
            },
            "status": {
              "type": "object",
              "description": "Asset's status information.",
              "properties": {
                "last_seen": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2024-12-18T18:22:18.582724Z",
                  "description": "UTC time when the Asset was last seen, formatted in RFC 3339."
                },
                "state": {
                  "type": "string",
                  "enum": [
                    "online",
                    "offline",
                    "unknown"
                  ]
                }
              }
            },
            "title": {
              "type": "string",
              "example": "Well 01",
              "maxLength": 64,
              "description": "Display name (`title`) of the Asset."
            },
            "updated": {
              "type": "string",
              "format": "date-time",
              "example": "2024-12-18T18:22:18.582724Z",
              "description": "UTC time when any Asset keys were last updated, formatted in RFC 3339."
            }
          },
          "type": "object"
        }
      },
      "400": {
        "description": ""
      },
      "401": {
        "description": ""
      },
      "404": {
        "description": ""
      },
      "500": {
        "description": ""
      }
    },
    "last_updated": "2026-02-04"
  }
}