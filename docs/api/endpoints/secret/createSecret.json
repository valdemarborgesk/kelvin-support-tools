{
  "id": "api/endpoints/secret/createSecret",
  "title": "Create Secret",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Create Secret\n\nCreate a new Secret.\n\nOnce this is created you can not change or see the value itself from Kelvin API. Retrieval of the value can only be done through an App.\n\n## Endpoint\n\n`POST /secrets/create`",
  "summary": "Create Secret",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/secrets/create' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.secret.createSecret()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/secret"
  ],
