{
  "id": "api/endpoints/instance/updateInstanceSettingsKelvinCluster",
  "title": "Update Kelvin Cluster Instance Setting",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Update Kelvin Cluster Instance Setting\n\nUpdates an existing Kelvin Cluster Instance Settings with any new values passed through the body parameters. All body parameters are optional and if not provided will remain unchanged.\n\n## Endpoint\n\n`POST /instance/settings/kelvin-cluster/update`",
  "summary": "Update Kelvin Cluster Instance Setting",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/instance/settings/kelvin-cluster/update' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.instance.updateInstanceSettingsKelvinCluster()\nprint(response)"
    }
  ],
