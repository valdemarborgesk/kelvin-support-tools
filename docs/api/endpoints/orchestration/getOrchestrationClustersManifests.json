  "metadata": {
    "path": "/orchestration/clusters/{cluster_name}/manifests/get",
    "method": "GET",
    "operation_id": "getOrchestrationClustersManifests",
    "tag": "Orchestration",
    "permission": "kelvin.permission.cluster.read",
    "parameters": [
      {
        "name": "cluster_name",
        "in": "path",
        "required": true,
        "description": "Cluster key `name` to retrieve provision yaml file. The string can only contain lowercase alphanumeric characters and `.`, `_` or `-` characters.",
        "type": "string"
      },
      {
        "name": "version",
        "in": "query",
        "required": true,
        "description": "Current version of the key `kelvin_version` in `version` object of the Cluster parameters.",
        "type": "string"
      }
    ],
    "request_body": null,
    "responses": {
