      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/orchestration/clusters/{cluster_name}/manifests/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
