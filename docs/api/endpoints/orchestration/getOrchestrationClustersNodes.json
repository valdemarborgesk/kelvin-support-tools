{
  "id": "api/endpoints/orchestration/getOrchestrationClustersNodes",
  "title": "Get Node",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Get Node\n\nRetrieve the parameters and status of a specific Node on a Cluster.\n\n## Endpoint\n\n`GET /orchestration/clusters/{cluster_name}/nodes/{node_name}/get`",
  "summary": "Get Node",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/orchestration/clusters/{cluster_name}/nodes/{node_name}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.orchestration.getOrchestrationClustersNodes()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/orchestration"
  ],
