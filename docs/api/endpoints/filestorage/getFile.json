{
  "id": "api/endpoints/filestorage/getFile",
  "title": "Get file info",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Get file info\n\nFetches the information for a specific file\n\n## Endpoint\n\n`GET /filestorage/{file_id}/get`",
  "summary": "Get file info",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X GET \\\n  'https://api.kelvininc.com/api/v4/filestorage/{file_id}/get' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.filestorage.getFile()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/filestorage"
  ],
