{
  "id": "api/endpoints/filestorage/uploadFile",
  "title": "Upload a file",
  "type": "api_endpoint",
  "category": "api",
  "content": "# Upload a file\n\nUpload a file\n\n## Endpoint\n\n`POST /filestorage/upload`",
  "summary": "Upload a file",
  "source": "openapi.json",
  "code_examples": [
    {
      "language": "bash",
      "code": "curl -X POST \\\n  'https://api.kelvininc.com/api/v4/filestorage/upload' \\\n  -H 'Authorization: Bearer $TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{...}'"
    },
    {
      "language": "python",
      "code": "from kelvin.api import Client\n\nclient = Client(api_key=\"your-api-key\")\nresponse = client.filestorage.uploadFile()\nprint(response)"
    }
  ],
  "related": [
    "api/schemas/filestorage"
  ],
  "tags": [
    "filestorage",
    "api",
    "post"
  ],
  "metadata": {
    "path": "/filestorage/upload",
    "method": "POST",
    "operation_id": "uploadFile",
    "tag": "Filestorage",
    "permission": "kelvin.permission.filestorage.upload",
    "parameters": [],
    "request_body": null,
    "responses": {
      "201": {
        "description": "File uploaded successfully",
        "schema": {
          "properties": {
            "file_id": {
              "type": "string",
              "example": "50FDD765-DBD7-4C7C-844D-E6211C9CD9E7",
              "description": "Generated UUID for a file"
            },
            "file_name": {
              "type": "string",
              "example": "test.csv",
              "maxLength": 128,
              "description": "Actual file name"
            },
            "file_size": {
              "type": "integer",
              "example": 300,
              "description": "File size in bytes"
            },
            "checksum": {
              "type": "string",
              "example": "e07de9b7a1788fe439bd1d9a114d1a3ee4eb5b29f8a9e11057f7c31d718c5614",
              "description": "File SHA256 checksum"
            },
            "source": {
              "type": "string",
              "example": "krn:user:user1",
              "description": "Resource that uploaded the file"
            },
            "created": {
              "type": "string",
              "format": "date-time",
              "example": "2024-02-20T22:22:18.582724Z",
              "description": "UTC time representing when the file was uploaded, formatted in RFC 3339."
            },
            "metadata": {
              "type": "object",
              "additionalProperties": true,
              "example": {
                "property1": true,
                "property2": 2
              },
              "description": "A free-form JSON object representing the files metadata"
            }
          },
          "type": "object"
        }
      },
      "400": {
        "description": ""
      },
      "401": {
        "description": ""
      }
    },
    "last_updated": "2026-02-04"
  }
